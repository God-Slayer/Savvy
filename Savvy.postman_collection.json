{
  "info":{"name":"Savvy API","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},
  "variable":[{"key":"baseUrl","value":"https://localhost:7026"}],
  "item":[
    {"name":"Auth - Admin","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"email\":\"admin@savvy.local\",\"password\":\"SavvyDemo!2026#LocalDB\"}"},"url":"{{baseUrl}}/api/auth/login"},"event":[{"listen":"test","script":{"exec":["pm.test('Login succeeds',()=>pm.expect(pm.response.code).to.be.oneOf([200,201]));","if(pm.response.code===200){pm.environment.set('adminToken',pm.response.json().accessToken);}"],"type":"text/javascript"}}]},
    {"name":"Auth - Manager","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"email\":\"manager@savvy.local\",\"password\":\"SavvyDemo!2026#LocalDB\"}"},"url":"{{baseUrl}}/api/auth/login"},"event":[{"listen":"test","script":{"exec":["pm.test('Login succeeds',()=>pm.expect(pm.response.code).to.be.oneOf([200,201]));","if(pm.response.code===200){let t=pm.response.json().accessToken;pm.environment.set('managerToken',t);let p=JSON.parse(atob(t.split('.')[1]));pm.environment.set('practiceId',p.practice_id);}"],"type":"text/javascript"}}]},
    {"name":"Auth - Clinician","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"email\":\"clinician@savvy.local\",\"password\":\"SavvyDemo!2026#LocalDB\"}"},"url":"{{baseUrl}}/api/auth/login"},"event":[{"listen":"test","script":{"exec":["pm.test('Login succeeds',()=>pm.expect(pm.response.code).to.be.oneOf([200,201]));","if(pm.response.code===200){pm.environment.set('clinicianToken',pm.response.json().accessToken);}"],"type":"text/javascript"}}]},
    {"name":"List shifts","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"}],"url":"{{baseUrl}}/api/practices/{{practiceId}}/shifts"},"event":[{"listen":"test","script":{"exec":["pm.test('Shift list succeeds',()=>pm.expect(pm.response.code).to.equal(200));","if(pm.response.code===200){let a=pm.response.json();let x=Array.isArray(a)?a[0]:a.value?.[0];if(x)pm.environment.set('shiftId',x.id);}"],"type":"text/javascript"}}]},
    {"name":"Get shift","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"}],"url":"{{baseUrl}}/api/shifts/{{shiftId}}"}},
    {"name":"Submit timesheet","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{clinicianToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"businessReference\":\"{{$guid}}\",\"actualStartUtc\":\"2026-07-20T08:00:00Z\",\"actualEndUtc\":\"2026-07-20T16:00:00Z\",\"unpaidBreakMinutes\":30,\"notes\":\"Postman demo\"}"},"url":"{{baseUrl}}/api/shifts/{{shiftId}}/timesheet"}},
    {"name":"Get timesheet","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"}],"url":"{{baseUrl}}/api/timesheets/{{timesheetId}}"}},
    {"name":"Approve timesheet","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"}],"url":"{{baseUrl}}/api/timesheets/{{timesheetId}}/approve"}},
    {"name":"Create payment run","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"businessReference\":\"{{$guid}}\",\"periodStartDate\":\"2026-07-01\",\"periodEndDate\":\"2026-07-31\",\"percentageFeeRate\":0,\"fixedFeeAmount\":0,\"currency\":\"GBP\"}"},"url":"{{baseUrl}}/api/practices/{{practiceId}}/payment-runs"}},
    {"name":"Get payment run","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"}],"url":"{{baseUrl}}/api/payment-runs/{{paymentRunId}}"}},
    {"name":"Process payment run","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"}],"url":"{{baseUrl}}/api/payment-runs/{{paymentRunId}}/process"}},
    {"name":"Reporting summary","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{managerToken}}"}],"url":"{{baseUrl}}/api/practices/{{practiceId}}/reports/summary?from=2026-07-01&to=2026-07-31"}},
    {"name":"Unauthorized check","request":{"method":"GET","url":"{{baseUrl}}/api/practices/{{practiceId}}/shifts"},"event":[{"listen":"test","script":{"exec":["pm.test('Unauthorized is rejected',()=>pm.expect(pm.response.code).to.equal(401));"],"type":"text/javascript"}}]}
  ]
}
